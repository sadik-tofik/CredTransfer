# ============================================================
# CredTransfer — Environment Variables Template
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to version control.
# ============================================================

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your_jwt_secret_here

# Blockchain
PRIVATE_KEY=your_wallet_private_key
INFURA_API_KEY=your_infura_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
CONTRACT_ADDRESS=0xYourContractAddress
NETWORK=zkSync
ETHEREUM_RPC_URL=https://sepolia.era.zksync.dev
ETHEREUM_PRIVATE_KEY=your_ethereum_private_key
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddress
NEXT_PUBLIC_ETHEREUM_NETWORK=zkSync

# Payment Gateways (Chapa)
CHAPA_SECRET_KEY=CHASECK_TEST-your_chapa_secret_key
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your_chapa_public_key

# Payment Gateways (Telebirr)
TELEBIRR_APP_KEY=your_telebirr_app_key
TELEBIRR_APP_SECRET=your_telebirr_app_secret
TELEBIRR_PUBLIC_KEY=your_telebirr_public_key
TELEBIRR_SHORT_CODE=your_short_code

# Storage
SUPABASE_STORAGE_BUCKET=documents
IPFS_PROJECT_ID=your_ipfs_project_id
IPFS_PROJECT_SECRET=your_ipfs_project_secret
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key

# Redis/Upstash (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@yourdomain.com

# Security
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
CORS_ORIGIN=http://localhost:3000,https://your-domain.vercel.app
SESSION_MAX_AGE=604800
BCRYPT_ROUNDS=12

# Feature Flags
ENABLE_2FA=false
ENABLE_IPFS_BACKUP=true
ENABLE_BLOCKCHAIN_VERIFICATION=true
ENABLE_PAYMENT_GATEWAYS=true
